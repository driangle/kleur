{
  "name": "kleur",
  "version": "0.1.0",
  "description": "A cross-language color manipulation library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typeCheck": "tsc",
    "build": "tsup",
    "test": "vitest run",
    "lint": "echo \"lint not yet configured\""
  },
  "keywords": [
    "color",
    "colour",
    "rgb",
    "hsl",
    "hex"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
